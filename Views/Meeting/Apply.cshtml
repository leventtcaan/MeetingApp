@{
    ViewBag.Title = "Meeting Application";
}

<h1 class="h4 text-center">Meeting participation form</h1>
<form method="post" action="/Meeting/Apply">
    <div class="mb-3">
        <label for="Name" class="form-label">Name</label>
        <input type="text" name="Name" id="Name" class="form-control">
    </div>

    <div class="mb-3">
        <label for="Phone" class="form-label">Phone</label>
        <input type="text" name="Phone" id="Phone" class="form-control">
    </div>

    <div class="mb-3">
        <label for="Email" class="form-label">Email</label>
        <input type="email" name="Email" id="Email" class="form-control">
    </div>

    <div class="mb-3">
        <label for="Participation" class="form-label">Participation Status</label>
        <select name="Participation" id="Participation" class="form-select">
            <option value="true">Yes</option>
            <option value="false">No</option>
        </select>
    </div>
    <button class="btn btn-primary mt-3 " type="submit">Submit</button>
</form>